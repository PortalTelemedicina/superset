# -----------------------------------------------------------------------
# PTM development overrides — copy to docker-compose.override.yml to use.
# Do not edit upstream docker-compose.yml for PTM-specific needs.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up
# -----------------------------------------------------------------------

services:
  superset:
    environment:
      # Enable PTM extension (frontend reads this via bootstrap feature_flags)
      - PTM_EXTENSION_ENABLED=true
    # Add more env or volumes here if needed; upstream compose is unchanged.
